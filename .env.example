# ── Quran Foundation ─────────────────────────────────────────────                                                                                                                                     
QF_CLIENT_ID=your-client-id                                      
QF_CLIENT_SECRET=your-client-secret                                                                                                                                                                     
QF_OAUTH_BASE=https://prelive-oauth2.quran.foundation
QF_CONTENT_BASE=https://apis-prelive.quran.foundation/content/api/v4                                                                                                                                    
QF_USER_BASE=https://apis-prelive.quran.foundation/auth/v1
# Quran Reflect gateway — community posts and scholar answers (post.read comment.read scopes)
QF_REFLECT_BASE=https://apis.quran.foundation

# ── Supabase ─────────────────────────────────────────────────────                                                                                                                                     
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co                                                                                                                                               
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                                                                                                                                                             
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key                                                                                                                                                         
                                                                                                                                                                                                        
# ── App ──────────────────────────────────────────────────────────                                                                                                                                     
NEXT_PUBLIC_APP_URL=http://localhost:3000                                                                                                                                                               
                                                                                                                                                                                                        
# ── Push notifications ───────────────────────────────────────────                                                                                                                                     
# Generate with: npx web-push generate-vapid-keys                                                                                                                                                       
VAPID_SUBJECT=mailto:you@example.com                                                                                                                                                                    
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key                                                                                                                                                      
VAPID_PRIVATE_KEY=your-vapid-private-key                                                                                                                                                                
                                                                                                                                                                                                        
# ── Cron ─────────────────────────────────────────────────────────                                                                                                                                     
# Generate with: openssl rand -hex 32                                                                                                                                                                   
CRON_SECRET=your-random-secret